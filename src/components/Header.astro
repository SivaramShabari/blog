---
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgb(var(--surface));
		border-bottom: 1px solid var(--border);
	}
	nav {
		display: flex;
		align-items: center;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a {
		display: inline-block;
		padding: 1em 0.5em;
		color: rgb(var(--text));
		text-decoration: none;
	}
</style>
